<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.stat.dal.mapper.DocumentsDataMapper">

    <resultMap id="BaseResultMap" type="com.stat.dal.po.DocumentsDataPO">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="project_id" property="projectId" jdbcType="VARCHAR"/>
        <result column="username" property="username" jdbcType="VARCHAR"/>
        <result column="document_id" property="documentId" jdbcType="VARCHAR"/>
        <result column="title" property="title" jdbcType="VARCHAR"/>
        <result column="href" property="href" jdbcType="VARCHAR"/>
        <result column="sort_order" property="sortOrder" jdbcType="INTEGER"/>
        <result column="created_time" property="createdTime" jdbcType="TIMESTAMP"/>
        <result column="updated_time" property="updatedTime" jdbcType="TIMESTAMP"/>
        <result column="created_by" property="createdBy" jdbcType="VARCHAR"/>
        <result column="updated_by" property="updatedBy" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, project_id, username, document_id, title, href,
        sort_order, created_time, updated_time, created_by, updated_by
    </sql>

    <insert id="insert" parameterType="com.stat.dal.po.DocumentsDataPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sas_documents_data (
            project_id, username, document_id, title, href,
            sort_order, created_by
        ) VALUES (
            #{projectId}, #{username}, #{documentId}, #{title}, #{href},
            #{sortOrder}, #{createdBy}
        )
    </insert>

    <update id="updateById" parameterType="com.stat.dal.po.DocumentsDataPO">
        UPDATE sas_documents_data SET
            document_id = #{documentId},
            title = #{title},
            href = #{href},
            sort_order = #{sortOrder},
            updated_time = NOW(),
            updated_by = #{updatedBy}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sas_documents_data WHERE id = #{id}
    </delete>

    <delete id="deleteByProjectId">
        DELETE FROM sas_documents_data WHERE project_id = #{projectId} AND username = #{username}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sas_documents_data WHERE id = #{id}
    </select>

    <select id="selectByProjectId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sas_documents_data
        WHERE project_id = #{projectId} AND username = #{username}
        ORDER BY sort_order ASC
    </select>

</mapper>
