<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.stat.dal.mapper.FileVersionHistoryMapper">

    <resultMap id="BaseResultMap" type="com.stat.common.entity.FileVersionHistory">
        <id column="id" property="id" />
        <result column="file_id" property="fileId" />
        <result column="project_id" property="projectId" />
        <result column="username" property="username" />
        <result column="file_category" property="fileCategory" />
        <result column="version_number" property="versionNumber" />
        <result column="original_name" property="originalName" />
        <result column="server_file_name" property="serverFileName" />
        <result column="file_path" property="filePath" />
        <result column="file_size" property="fileSize" />
        <result column="file_extension" property="fileExtension" />
        <result column="file_md5" property="fileMd5" />
        <result column="upload_time" property="uploadTime" />
        <result column="process_status" property="processStatus" />
        <result column="replaced_time" property="replacedTime" />
        <result column="replaced_by" property="replacedBy" />
    </resultMap>

    <select id="selectByProjectIdAndCategory" resultMap="BaseResultMap">
        SELECT * FROM file_version_history
        WHERE project_id = #{projectId}
          AND file_category = #{fileCategory}
        ORDER BY version_number DESC
    </select>

</mapper>
