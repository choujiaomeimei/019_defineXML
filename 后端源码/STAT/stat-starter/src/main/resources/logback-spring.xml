<?xml version="1.0" encoding="UTF-8"?>
<!-- 日志级别从低到高分为TRACE < DEBUG < INFO < WARN < ERROR < FATAL，如果设置为WARN，则低于WARN的信息都不会输出 -->
<configuration debug="true" scan="true">
    <!--从环境变量中获取APP_ID,日志文件保存到指定位置-->
    <property name="LOG_PATH" value="${APP_ID}/${hostName}"/>
    <property name="CONSOLE_LOG_PATTERN" value="[%d{yyyy-MM-dd HH:mm:ss.SSS}] %-5level [%thread] %logger{36} %L - %msg%n"/>
    <property name="FILE_LOG_PATTERN" value="[%d{yyyy-MM-dd HH:mm:ss.SSS}] %-5level [%thread] %logger{36} %L - %msg%n"/>

    <springProperty scope="context" name="logging.level.root" source="logging.level.root" defaultValue="INFO"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- SQL日志专用appender -->
    <appender name="SQL-STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>[%d{yyyy-MM-dd HH:mm:ss.SSS}] %-5level [SQL] %n==> %msg %n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <file>${LOG_PATH}/applog.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_ID}-%d{yyyyMMdd}-%i.log.gz</fileNamePattern>
            <maxFileSize>500MB</maxFileSize>
            <maxHistory>24</maxHistory>  <!-- 保存24天 -->
            <totalSizeCap>10GB</totalSizeCap><!-- 总日志大小 -->
        </rollingPolicy>
    </appender>

    <appender name="ASYNC-FILE" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>1024</queueSize>
        <neverBlock>true</neverBlock>
        <!-- 异步打印堆栈信息不丢失-->
        <includeCallerData>true</includeCallerData>
        <!-- 添加附加的appender,最多只能添加一个 -->
        <appender-ref ref="FILE"/>
    </appender>

    <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>1024</queueSize>
        <neverBlock>true</neverBlock>
        <!-- 异步打印堆栈信息不丢失-->
        <includeCallerData>true</includeCallerData>
        <!-- 添加附加的appender,最多只能添加一个 -->
        <appender-ref ref="STDOUT"/>
    </appender>

    <!-- 开发环境：SQL日志使用表格样式 -->
    <springProfile name="dev,local,uat">
        <logger name="com.stat.dal.mapper" level="DEBUG" additivity="false">
            <appender-ref ref="SQL-STDOUT"/>
            <appender-ref ref="FILE"/>
        </logger>
        
        <!-- MyBatis SQL详细日志 -->
        <logger name="org.apache.ibatis" level="DEBUG" additivity="false">
            <appender-ref ref="SQL-STDOUT"/>
        </logger>
        
        <!-- JDBC结果集日志 -->
        <logger name="java.sql.ResultSet" level="DEBUG" additivity="false">
            <appender-ref ref="SQL-STDOUT"/>
        </logger>
        
        <!-- JDBC连接日志 -->
        <logger name="java.sql.Connection" level="DEBUG" additivity="false">
            <appender-ref ref="SQL-STDOUT"/>
        </logger>
        
        <!-- JDBC参数日志 -->
        <logger name="java.sql.PreparedStatement" level="DEBUG" additivity="false">
            <appender-ref ref="SQL-STDOUT"/>
        </logger>
    </springProfile>
    
    <!-- 生产环境：关闭详细SQL和调试日志 -->
    <springProfile name="prod">
        <logger name="com.stat.dal.mapper" level="WARN" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
        
        <logger name="org.apache.ibatis" level="WARN" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
        
        <logger name="java.sql" level="WARN" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
    </springProfile>
    
    <!-- 开发环境：Service和Controller层DEBUG日志 -->
    <springProfile name="dev,local,uat">
        <logger name="com.stat.service" level="DEBUG" additivity="false">
            <appender-ref ref="STDOUT"/>
            <appender-ref ref="FILE"/>
        </logger>
        
        <logger name="com.stat.web.controller" level="DEBUG" additivity="false">
            <appender-ref ref="STDOUT"/>
            <appender-ref ref="FILE"/>
        </logger>
    </springProfile>
    
    <!-- 生产环境：Service和Controller层只记录重要信息 -->
    <springProfile name="prod">
        <logger name="com.stat.service" level="INFO" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
        
        <logger name="com.stat.web.controller" level="INFO" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
    </springProfile>

    <!-- 开发环境：输出到控制台和文件 -->
    <springProfile name="dev,local,uat">
        <root level="${logging.level.root}">
            <appender-ref ref="ASYNC"/>
            <appender-ref ref="ASYNC-FILE"/>
        </root>
    </springProfile>
    
    <!-- 生产环境：只输出到文件，提升性能 -->
    <springProfile name="prod">
        <root level="${logging.level.root}">
            <appender-ref ref="ASYNC-FILE"/>
        </root>
    </springProfile>

</configuration>